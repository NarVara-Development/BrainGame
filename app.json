{
  "expo": {
    "name": "NarVara BrainGame",
    "slug": "narvara-braingame",
    "owner": "narvaradev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "narvarabraingame",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffd400"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.narvara.braingame"
    },
    "android": {
      "package": "com.narvara.braingame",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffd400"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "react-native-iap",
      "@react-native-firebase/app",
      "@react-native-firebase/analytics"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea673c5c-9701-4dde-9906-9b031bcd00aa"
      }
    }
  }
}
